{
  "info": {
    "_postman_id": "d7f7a7e7-6a0e-4bb7-8b0d-8b7e1e3f1a01",
    "name": "M3 Keycloak JWT demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Step-by-step collection for Keycloak client_credentials and the JWT-protected M3 Orders API."
  },
  "item": [
    {
      "name": "01 - Get access token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "url": {
          "raw": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token"
        },
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "{{client_id}}",
              "type": "text"
            },
            {
              "key": "client_secret",
              "value": "{{client_secret}}",
              "type": "text"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('access_token', data.access_token);",
              "pm.test('access token exists', function () {",
              "  pm.expect(data.access_token).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - List orders",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base_url}}/orders"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.test('response is an array', function () {",
              "  pm.expect(data).to.be.an('array');",
              "});",
              "if (Array.isArray(data) && data.length > 0) {",
              "  pm.collectionVariables.set('order_id', data[0].id);",
              "}",
              "pm.test('at least one order exists', function () {",
              "  pm.expect(data.length).to.be.greaterThan(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 - Get order detail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base_url}}/orders/{{order_id}}"
        }
      }
    },
    {
      "name": "04 - Create order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{api_base_url}}/orders"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer\": \"Gamma Srl\",\n  \"order_date\": \"2026-05-18\",\n  \"status\": \"new\",\n  \"lines\": [\n    {\n      \"sku\": \"MOUSE-001\",\n      \"description\": \"Wireless mouse\",\n      \"quantity\": 4,\n      \"unit_price\": 18.5\n    },\n    {\n      \"sku\": \"PAD-002\",\n      \"description\": \"Mouse pad\",\n      \"quantity\": 4,\n      \"unit_price\": 4.25\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "pm.collectionVariables.set('created_order_id', data.id);",
              "pm.test('order created', function () {",
              "  pm.expect(pm.response.code).to.eql(201);",
              "  pm.expect(data.id).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Get created order lines",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{api_base_url}}/orders/{{created_order_id}}/lines"
        }
      }
    }
  ]
}
